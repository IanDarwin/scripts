#!/bin/sh

JARHOME=~ian/lib
JAR=sendsms-1.0.0-SNAPSHOT-jar-with-dependencies.jar
JAVA=/usr/local/jdk-25/bin/java

case $# in
0|1)	echo "Usage: $0 nameber message..." 2>&1
	exit 1
	;;
esac

PHONENUM=$1
shift
MESSAGE="$@"

echo + $JAVA -jar ${JARHOME}/${JAR} $PHONENUM "${MESSAGE}"

$JAVA -jar ${JARHOME}/${JAR} $PHONENUM "${MESSAGE}"
